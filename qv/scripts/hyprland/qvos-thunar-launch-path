#!/bin/bash
set -euo pipefail

mode="${1:-}"
shift || true

path="$HOME"
args=("$@")

if ((${#args[@]} > 0)); then
  start=$((${#args[@]} - 1))
  end=-1
  step=-1
  for ((index = start; index != end; index += step)); do
    candidate="${args[$index]}"
    [[ -n "${candidate:-}" ]] || continue
    candidate="${candidate/#\~/$HOME}"
    candidate="${candidate%\"}"
    candidate="${candidate#\"}"
    candidate="${candidate%\'}"
    candidate="${candidate#\'}"
    if [[ -d "$candidate" ]]; then
      path="$candidate"
      break
    fi
    if [[ -e "$candidate" ]]; then
      path="$(dirname -- "$candidate")"
      break
    fi
  done
fi

case "$mode" in
terminal)
  exec uwsm-app -- xdg-terminal-exec --dir="$path"
  ;;
editor)
  if command -v omarchy-launch-editor >/dev/null 2>&1; then
    exec env EDITOR="${EDITOR:-${VISUAL:-}}" omarchy-launch-editor "$path"
  fi

  editor_cmd="${EDITOR:-${VISUAL:-}}"
  if [[ -z $editor_cmd ]]; then
    notify-send -u critical "Editor" "No default editor is configured"
    exit 1
  fi

  case "$editor_cmd" in
  nvim | vim | nano | micro | hx | helix | fresh)
    exec uwsm-app -- xdg-terminal-exec --dir="$path" -e "$editor_cmd" .
    ;;
  code | code-oss | codium | vscodium)
    exec setsid uwsm-app -- "$editor_cmd" --new-window "$path"
    ;;
  *)
    exec setsid uwsm-app -- "$editor_cmd" "$path"
    ;;
  esac
  ;;
codex | claude | gemini | opencode)
  # shellcheck disable=SC2016
  exec setsid uwsm-app -- xdg-terminal-exec --app-id="org.qvos.$mode" bash -lc 'cd "$1" || exit; exec "$2"' qvos "$path" "$mode"
  ;;
*)
  printf 'Usage: qvos-thunar-launch-path <terminal|editor|codex|claude|gemini|opencode> <path>\n' >&2
  exit 2
  ;;
esac
