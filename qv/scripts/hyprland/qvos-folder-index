#!/bin/bash
set -euo pipefail

search_root="${1:-${QVOS_PROJECT_ROOT:-$HOME}}"
map_file="${QVOS_FOLDER_MAP:-}"

[[ -d "$search_root" ]] || search_root="$HOME"

folder_paths() {
  if command -v fd >/dev/null 2>&1; then
    fd --hidden --type d --max-depth 8 \
      --exclude .cache \
      --exclude .mozilla \
      --exclude .git \
      --exclude node_modules \
      --exclude .venv \
      --exclude vendor \
      --exclude Trash \
      . "$search_root" 2>/dev/null |
      sed 's#/*$##'
    return
  fi

  find "$search_root" -xdev -maxdepth 8 \
    -path "$HOME/.cache" -prune -o \
    -path "$HOME/.mozilla" -prune -o \
    -path "$HOME/.local/share/Trash" -prune -o \
    -path '*/.git' -prune -o \
    -path '*/node_modules' -prune -o \
    -path '*/.venv' -prune -o \
    -path '*/vendor' -prune -o \
    -type d -print 2>/dev/null
}

sort_keyed_path() {
  local path="$1"
  local relative depth

  relative="${path/#$HOME/}"
  [[ "$path" == "$HOME" ]] && relative="/"
  depth="${relative//[^\/]/}"
  printf '%03d\t%05d\t%s\t%s\n' "${#depth}" "${#relative}" "$relative" "$path"
}

[[ -z "$map_file" ]] || rm -f -- "$map_file"

folder_paths |
  while IFS= read -r path; do
    sort_keyed_path "$path"
  done |
  sort -n -k1,1 -n -k2,2 -f -k3,3 |
  awk -v map="$map_file" -v home="$HOME" '
    BEGIN { FS = "\t"; OFS = "\t" }
    {
      path = $4
      n += 1
      paths[n] = path
      base = path
      sub(/^.*\//, "", base)
      if (path == home) {
        base = "Home"
      }
      parent = path
      sub(/\/[^/]*$/, "", parent)
      sub(/^.*\//, "", parent)
      if (parent == "" || parent == base) {
        parent = "root"
      }
      bases[n] = base
      parents[n] = parent
      counts[base] += 1
    }
    END {
      for (i = 1; i <= n; i++) {
        display = bases[i]
        if (counts[bases[i]] > 1) {
          display = bases[i] " - " parents[i]
        }
        seen[display] += 1
        if (seen[display] > 1) {
          display = display " " seen[display]
        }
        print display
        if (map != "") {
          print display, paths[i] >> map
        }
      }
    }
  '
