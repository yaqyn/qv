#!/bin/bash
set -euo pipefail

mode="${1:-attach}"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/qvos"
favorites_file="$config_dir/tmux-favorites"
renamed_file="$config_dir/tmux-renamed"

if ! command -v omarchy-launch-walker >/dev/null 2>&1; then
  notify-send -u critical "Tmux" "omarchy-launch-walker was not found"
  exit 1
fi

current_dir() {
  omarchy-cmd-terminal-cwd 2>/dev/null || printf '%s\n' "$HOME"
}

internal_session() {
  [[ $1 == "qvos-restore" ]]
}

normalize_session_name() {
  local name="$1"

  name="${name//$'\n'/ }"
  name="${name//$'\t'/ }"
  name="${name//:/-}"
  printf '%s\n' "$name" | sed -E 's/^[[:space:]]+//;s/[[:space:]]+$//'
}

exact_session_exists() {
  local session="$1"

  tmux has-session -t "=$session" 2>/dev/null
}

next_session_name() {
  local base="$1"
  local name index

  name="$base"
  index=2
  while exact_session_exists "$name"; do
    name="$base $index"
    index=$((index + 1))
  done

  printf '%s\n' "$name"
}

suggested_session_name() {
  local cwd="${1:-$(current_dir)}"
  local location

  location="$(basename "$cwd")"
  [[ -n "$location" && "$location" != "/" ]] || location="root"
  [[ "$cwd" == "$HOME" ]] && location="home"
  location="${location//:/-}"

  next_session_name "$location tmux"
}

prompt_session_name() {
  local prompt="$1"
  local default="$2"

  printf '%s\n' "$default" |
    omarchy-launch-walker --dmenu --width 420 --minheight 1 --maxheight 120 -p "$prompt"
}

attach_named_session() {
  local session="$1"

  exec uwsm-app -- xdg-terminal-exec tmux attach -t "=$session"
}

create_named_session() {
  local session="$1"
  local cwd="$2"

  remember_renamed "$session"
  exec uwsm-app -- xdg-terminal-exec --dir="$cwd" tmux new -s "$session"
}

restore_sessions_if_needed() {
  if ! tmux has-session 2>/dev/null; then
    tmux new-session -d -s qvos-restore
    tmux source-file "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf" >/dev/null 2>&1 || true
    tmux run-shell "$HOME/.tmux/plugins/tmux-resurrect/scripts/restore.sh" >/dev/null 2>&1 || true
    sleep 1
    tmux kill-session -t =qvos-restore 2>/dev/null || true
  fi
}

current_session() {
  local session

  restore_sessions_if_needed
  session="$(
    {
      tmux list-sessions -F '#{session_activity}	#{session_name}' 2>/dev/null || true
    } |
      awk -F '\t' '$2 != "qvos-restore"' |
      sort -rn -k1,1 |
      head -n1 |
      cut -f2-
  )"
  if [[ -z "${session:-}" ]]; then
    notify-send "Tmux" "No running sessions"
    exit 0
  fi

  attach_named_session "$session"
}

attach_session() {
  local choice session sessions

  restore_sessions_if_needed

  sessions="$(session_lines)"

  choice="$(
    {
      [[ -n "$sessions" ]] && printf '%s\n' "$sessions"
      printf 'Rename\n'
      printf 'Duplicate\n'
      printf 'Favourite\n'
      printf 'Remove\n'
      printf 'Clear non-favourites\n'
      printf 'Save all\n'
      printf 'Save as...\n'
      printf '+ New\n'
    } |
      omarchy-launch-walker --dmenu --width 640 --minheight 1 --maxheight 420 -p "Tmux..."
  )"

  [[ -n "${choice:-}" ]] || exit 0

  case "$choice" in
  Rename) rename_session ;;
  Duplicate) duplicate_session ;;
  Favourite) favorite_session ;;
  Remove) remove_session ;;
  "Clear non-favourites") clear_except_favorites ;;
  "Save all") save_all ;;
  "Save as...") save_as_session ;;
  "+ New") new_session ;;
  esac

  session="$(session_from_line "$choice")"
  session="$(normalize_session_name "$session")"
  [[ -n "${session:-}" ]] || exit 0

  if exact_session_exists "$session"; then
    attach_named_session "$session"
  fi

  create_named_session "$session" "$(current_dir)"
}

session_lines() {
  local records favorites renamed name activity _windows stamp display

  records="$(tmux list-sessions -F '#{session_activity}	#{session_name}	#{session_windows}' 2>/dev/null | sort -rn -k1,1 || true)"
  favorites="$(favorite_names)"
  renamed="$(renamed_names)"

  while IFS=$'\t' read -r activity name _windows; do
    [[ -n "${name:-}" ]] || continue
    internal_session "$name" && continue
    if grep -Fqx "$name" <<<"$favorites"; then
      stamp="$(date -d "@$activity" '+%Y-%m-%d %H:%M')"
      display="$name"
      grep -Fqx "$name" <<<"$renamed" || display="$name $stamp"
      printf '* %s\n' "$display"
    fi
  done <<<"$records"

  while IFS=$'\t' read -r activity name _windows; do
    [[ -n "${name:-}" ]] || continue
    internal_session "$name" && continue
    if ! grep -Fqx "$name" <<<"$favorites"; then
      stamp="$(date -d "@$activity" '+%Y-%m-%d %H:%M')"
      display="$name"
      grep -Fqx "$name" <<<"$renamed" || display="$name $stamp"
      printf '  %s\n' "$display"
    fi
  done <<<"$records"
}

session_from_line() {
  local line="$1"

  line="${line#\* }"
  line="${line#  }"
  printf '%s\n' "$line" | sed -E 's/[[:space:]][0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}$//'
}

favorite_names() {
  [[ -f "$favorites_file" ]] || return 0
  grep -v '^[[:space:]]*$' "$favorites_file" | sort -u
}

renamed_names() {
  [[ -f "$renamed_file" ]] || return 0
  grep -v '^[[:space:]]*$' "$renamed_file" | sort -u
}

rename_session() {
  local session new_name

  session="$(choose_session "Rename")"
  [[ -n "${session:-}" ]] || exit 0

  new_name="$(
    prompt_session_name "New name..." "$session"
  )"
  new_name="$(normalize_session_name "$new_name")"
  [[ -n "${new_name:-}" ]] || exit 0

  if [[ "$new_name" != "$session" ]] && exact_session_exists "$new_name"; then
    notify-send -u critical "Tmux" "$new_name already exists"
    exit 1
  fi

  tmux rename-session -t "=$session" "$new_name"
  replace_favorite "$session" "$new_name"
  replace_renamed "$session" "$new_name"
  notify-send "Tmux" "Renamed $session to $new_name"
  exit 0
}

choose_session() {
  local prompt="$1"
  local line session

  line="$(
    session_lines |
      omarchy-launch-walker --dmenu --width 640 --minheight 1 --maxheight 420 -p "$prompt..."
  )"
  [[ -n "${line:-}" ]] || exit 0

  session="$(session_from_line "$line")"
  session="$(normalize_session_name "$session")"
  if ! exact_session_exists "$session"; then
    notify-send -u critical "Tmux" "$session is not a running session"
    exit 1
  fi

  printf '%s\n' "$session"
}

favorite_session() {
  local session

  session="$(choose_session "Favorite")"
  [[ -n "${session:-}" ]] || exit 0

  install -d "$config_dir"
  {
    favorite_names
    printf '%s\n' "$session"
  } | sort -u >"$favorites_file.tmp"
  mv "$favorites_file.tmp" "$favorites_file"
  notify-send "Tmux" "Favorited $session"
  exit 0
}

remove_session() {
  local session

  session="$(choose_session "Remove")"
  [[ -n "${session:-}" ]] || exit 0

  tmux kill-session -t "=$session"
  remove_favorite "$session"
  remove_renamed "$session"
  notify-send "Tmux" "Removed $session"
  exit 0
}

clear_except_favorites() {
  local favorites killed session

  favorites="$(favorite_names)"
  killed=0

  while IFS= read -r session; do
    [[ -n "$session" ]] || continue
    internal_session "$session" && continue
    if ! grep -Fqx "$session" <<<"$favorites"; then
      tmux kill-session -t "=$session" 2>/dev/null || true
      remove_favorite "$session"
      remove_renamed "$session"
      killed=$((killed + 1))
    fi
  done < <(tmux list-sessions -F '#S' 2>/dev/null)

  notify-send "Tmux" "Cleared $killed non-favourite sessions"
  exit 0
}

save_command() {
  local command="$HOME/.local/share/qvos/hyprland/qvos-tmux-save-now"

  [[ -x "$command" ]] || command="qvos-tmux-save-now"
  printf '%s\n' "$command"
}

save_all() {
  exec "$(save_command)" quick
}

save_as_session() {
  exec "$(save_command)"
}

replace_favorite() {
  local old_name="$1"
  local new_name="$2"

  [[ -f "$favorites_file" ]] || return 0
  awk -v old="$old_name" -v new="$new_name" '{ print ($0 == old ? new : $0) }' "$favorites_file" | sort -u >"$favorites_file.tmp"
  mv "$favorites_file.tmp" "$favorites_file"
}

remove_favorite() {
  local name="$1"

  [[ -f "$favorites_file" ]] || return 0
  grep -Fvx "$name" "$favorites_file" >"$favorites_file.tmp" || true
  mv "$favorites_file.tmp" "$favorites_file"
}

remove_renamed() {
  local name="$1"

  [[ -f "$renamed_file" ]] || return 0
  grep -Fvx "$name" "$renamed_file" >"$renamed_file.tmp" || true
  mv "$renamed_file.tmp" "$renamed_file"
}

replace_renamed() {
  local old_name="$1"
  local new_name="$2"

  install -d "$config_dir"
  {
    renamed_names | grep -Fvx "$old_name" || true
    printf '%s\n' "$new_name"
  } | sort -u >"$renamed_file.tmp"
  mv "$renamed_file.tmp" "$renamed_file"
}

remember_renamed() {
  local name="$1"

  install -d "$config_dir"
  {
    renamed_names
    printf '%s\n' "$name"
  } | sort -u >"$renamed_file.tmp"
  mv "$renamed_file.tmp" "$renamed_file"
}

duplicate_window_panes() {
  local source_window="$1"
  local target_window="$2"
  local pane_index pane_path first

  first=true
  while IFS=$'\t' read -r pane_index pane_path; do
    [[ -n "${pane_index:-}" ]] || continue
    if [[ "$first" == true ]]; then
      first=false
      continue
    fi

    pane_path="${pane_path:-$HOME}"
    tmux split-window -d -t "$target_window" -c "$pane_path" >/dev/null
  done < <(tmux list-panes -t "$source_window" -F '#{pane_index}	#{pane_current_path}' | sort -n -k1,1)

  tmux select-layout -t "$target_window" tiled >/dev/null 2>&1 || true
}

duplicate_session_layout() {
  local source="$1"
  local target="$2"
  local win_index win_name win_active first_path target_window active_target first

  first=true
  active_target=""
  while IFS=$'\t' read -r win_index win_name win_active first_path; do
    [[ -n "${win_index:-}" ]] || continue
    first_path="${first_path:-$HOME}"
    win_name="${win_name:-window}"

    if [[ "$first" == true ]]; then
      tmux new-session -d -s "$target" -n "$win_name" -c "$first_path"
      target_window="$(tmux list-windows -t "=$target" -F '#{window_id}' | head -n1)"
      first=false
    else
      target_window="$(tmux new-window -d -P -F '#{window_id}' -t "=$target" -n "$win_name" -c "$first_path")"
    fi

    duplicate_window_panes "=$source:$win_index" "$target_window"
    if [[ "$win_active" == "1" ]]; then
      active_target="$target_window"
    fi
  done < <(tmux list-windows -t "=$source" -F '#{window_index}	#{window_name}	#{window_active}	#{pane_current_path}')

  [[ -n "$active_target" ]] && tmux select-window -t "$active_target" >/dev/null 2>&1
}

duplicate_session() {
  local source target

  source="$(choose_session "Duplicate")"
  [[ -n "${source:-}" ]] || exit 0

  target="$(prompt_session_name "Duplicate as..." "$(next_session_name "$source copy")")"
  target="$(normalize_session_name "$target")"
  [[ -n "${target:-}" ]] || exit 0

  if exact_session_exists "$target"; then
    notify-send -u critical "Tmux" "$target already exists"
    exit 1
  fi

  duplicate_session_layout "$source" "$target"
  remember_renamed "$target"
  notify-send "Tmux" "Duplicated $source as $target"
  attach_named_session "$target"
}

new_session() {
  local cwd name

  cwd="$(current_dir)"
  name="$(prompt_session_name "New session..." "$(suggested_session_name "$cwd")")"
  name="$(normalize_session_name "$name")"
  [[ -n "${name:-}" ]] || exit 0

  if exact_session_exists "$name"; then
    attach_named_session "$name"
  fi

  create_named_session "$name" "$cwd"
}

case "$mode" in
current) current_session ;;
attach) attach_session ;;
new) new_session ;;
*)
  printf 'Usage: qvos-tmux-session-menu [current|attach|new]\n' >&2
  exit 2
  ;;
esac
