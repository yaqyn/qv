#!/bin/bash
set -euo pipefail

mode="${1:-attach}"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/qvos"
favorites_file="$config_dir/tmux-favorites"
renamed_file="$config_dir/tmux-renamed"

if ! command -v omarchy-launch-walker >/dev/null 2>&1; then
  notify-send -u critical "Tmux" "omarchy-launch-walker was not found"
  exit 1
fi

current_dir() {
  omarchy-cmd-terminal-cwd 2>/dev/null || printf '%s\n' "$HOME"
}

restore_sessions_if_needed() {
  if ! tmux has-session 2>/dev/null; then
    tmux new-session -d -s qvos-restore
    tmux source-file "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf" >/dev/null 2>&1 || true
    tmux run-shell "$HOME/.tmux/plugins/tmux-resurrect/scripts/restore.sh" >/dev/null 2>&1 || true
    sleep 1
    if [[ "$(tmux list-sessions -F '#S' 2>/dev/null | wc -l)" -gt 1 ]]; then
      tmux kill-session -t qvos-restore 2>/dev/null || true
    fi
  fi
}

current_session() {
  local session

  restore_sessions_if_needed
  session="$(tmux list-sessions -F '#{session_activity}	#{session_name}' 2>/dev/null | sort -rn -k1,1 | head -n1 | cut -f2-)"
  if [[ -z "${session:-}" ]]; then
    notify-send "Tmux" "No running sessions"
    exit 0
  fi

  exec uwsm-app -- xdg-terminal-exec tmux attach -t "$session"
}

attach_session() {
  local choice session sessions

  restore_sessions_if_needed

  sessions="$(session_lines)"

  if [[ -z "$sessions" ]]; then
    notify-send "Tmux" "No running sessions"
    exit 0
  fi

  choice="$(
    {
      printf '%s\n' "$sessions"
      printf 'Rename\n'
      printf 'Favourite\n'
      printf 'Remove\n'
      printf 'Clear\n'
      printf 'Save\n'
      printf '+ New\n'
    } |
      omarchy-launch-walker --dmenu --width 640 --minheight 1 --maxheight 420 -p "Tmux..."
  )"

  [[ -n "${choice:-}" ]] || exit 0

  case "$choice" in
  Rename) rename_session ;;
  Favourite) favorite_session ;;
  Remove) remove_session ;;
  Clear) clear_except_favorites ;;
  Save) save_session ;;
  "+ New") new_session ;;
  esac

  session="$(session_from_line "$choice")"
  [[ -n "${session:-}" ]] || exit 0
  exec uwsm-app -- xdg-terminal-exec tmux attach -t "$session"
}

session_lines() {
  local records favorites renamed name activity _windows stamp display

  records="$(tmux list-sessions -F '#{session_activity}	#{session_name}	#{session_windows}' 2>/dev/null | sort -rn -k1,1)"
  favorites="$(favorite_names)"
  renamed="$(renamed_names)"

  while IFS=$'\t' read -r activity name _windows; do
    [[ -n "${name:-}" ]] || continue
    if grep -Fqx "$name" <<<"$favorites"; then
      stamp="$(date -d "@$activity" '+%Y-%m-%d %H:%M')"
      display="$name"
      grep -Fqx "$name" <<<"$renamed" || display="$name $stamp"
      printf '* %s\n' "$display"
    fi
  done <<<"$records"

  while IFS=$'\t' read -r activity name _windows; do
    [[ -n "${name:-}" ]] || continue
    if ! grep -Fqx "$name" <<<"$favorites"; then
      stamp="$(date -d "@$activity" '+%Y-%m-%d %H:%M')"
      display="$name"
      grep -Fqx "$name" <<<"$renamed" || display="$name $stamp"
      printf '  %s\n' "$display"
    fi
  done <<<"$records"
}

session_from_line() {
  local line="$1"

  line="${line#\* }"
  line="${line#  }"
  printf '%s\n' "$line" | sed -E 's/[[:space:]][0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}$//'
}

favorite_names() {
  [[ -f "$favorites_file" ]] || return 0
  grep -v '^[[:space:]]*$' "$favorites_file" | sort -u
}

renamed_names() {
  [[ -f "$renamed_file" ]] || return 0
  grep -v '^[[:space:]]*$' "$renamed_file" | sort -u
}

rename_session() {
  local session new_name

  session="$(choose_session "Rename")"
  [[ -n "${session:-}" ]] || exit 0

  new_name="$(
    printf '%s\n' "$session" |
      omarchy-launch-walker --dmenu --width 420 --minheight 1 --maxheight 120 -p "New name..."
  )"
  [[ -n "${new_name:-}" ]] || exit 0

  tmux rename-session -t "$session" "$new_name"
  replace_favorite "$session" "$new_name"
  replace_renamed "$session" "$new_name"
  notify-send "Tmux" "Renamed $session to $new_name"
}

choose_session() {
  local prompt="$1"

  session_lines |
    omarchy-launch-walker --dmenu --width 640 --minheight 1 --maxheight 420 -p "$prompt..." |
    while IFS= read -r line; do
      session_from_line "$line"
    done
}

favorite_session() {
  local session

  session="$(choose_session "Favorite")"
  [[ -n "${session:-}" ]] || exit 0

  install -d "$config_dir"
  {
    favorite_names
    printf '%s\n' "$session"
  } | sort -u >"$favorites_file.tmp"
  mv "$favorites_file.tmp" "$favorites_file"
  notify-send "Tmux" "Favorited $session"
}

remove_session() {
  local session

  session="$(choose_session "Remove")"
  [[ -n "${session:-}" ]] || exit 0

  tmux kill-session -t "$session"
  remove_favorite "$session"
  notify-send "Tmux" "Removed $session"
}

clear_except_favorites() {
  local favorites killed session

  favorites="$(favorite_names)"
  killed=0

  while IFS= read -r session; do
    [[ -n "$session" ]] || continue
    if ! grep -Fqx "$session" <<<"$favorites"; then
      tmux kill-session -t "$session" 2>/dev/null || true
      killed=$((killed + 1))
    fi
  done < <(tmux list-sessions -F '#S' 2>/dev/null)

  notify-send "Tmux" "Cleared $killed non-favourite sessions"
}

save_session() {
  exec ~/.local/share/qvos/hyprland/qvos-tmux-save-now
}

replace_favorite() {
  local old_name="$1"
  local new_name="$2"

  [[ -f "$favorites_file" ]] || return 0
  awk -v old="$old_name" -v new="$new_name" '{ print ($0 == old ? new : $0) }' "$favorites_file" | sort -u >"$favorites_file.tmp"
  mv "$favorites_file.tmp" "$favorites_file"
}

remove_favorite() {
  local name="$1"

  [[ -f "$favorites_file" ]] || return 0
  grep -Fvx "$name" "$favorites_file" >"$favorites_file.tmp" || true
  mv "$favorites_file.tmp" "$favorites_file"
}

replace_renamed() {
  local old_name="$1"
  local new_name="$2"

  install -d "$config_dir"
  {
    renamed_names | grep -Fvx "$old_name" || true
    printf '%s\n' "$new_name"
  } | sort -u >"$renamed_file.tmp"
  mv "$renamed_file.tmp" "$renamed_file"
}

new_session() {
  local cwd location base name index

  cwd="$(current_dir)"
  location="$(basename "$cwd")"
  [[ -n "$location" && "$location" != "/" ]] || location="root"
  [[ "$cwd" == "$HOME" ]] && location="home"
  location="${location//:/-}"

  base="$location tmux"
  index=1
  name="$base $index"
  while tmux has-session -t "$name" 2>/dev/null; do
    index=$((index + 1))
    name="$base $index"
  done

  schedule_auto_save "$name"
  exec uwsm-app -- xdg-terminal-exec --dir="$cwd" tmux new -s "$name"
}

schedule_auto_save() {
  local session="$1"
  local save_script="$HOME/.tmux/plugins/tmux-resurrect/scripts/save.sh"

  (
    sleep 60
    tmux has-session -t "$session" 2>/dev/null || exit 0
    [[ -x "$save_script" ]] || exit 0
    tmux run-shell "$save_script"
    notify-send "Tmux saved" "$session survived 1 minute"
  ) >/dev/null 2>&1 &
}

case "$mode" in
current) current_session ;;
attach) attach_session ;;
new) new_session ;;
*)
  printf 'Usage: qvos-tmux-session-menu [current|attach|new]\n' >&2
  exit 2
  ;;
esac
