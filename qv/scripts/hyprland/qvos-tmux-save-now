#!/bin/bash
set -euo pipefail

mode="${1:-dialog}"

if ! command -v tmux >/dev/null 2>&1; then
  notify-send -u critical "Tmux" "tmux is not installed"
  exit 1
fi

save_script="$HOME/.tmux/plugins/tmux-resurrect/scripts/save.sh"

require_save_script() {
  if [[ ! -x $save_script ]]; then
    notify-send -u critical "Tmux" "tmux-resurrect save script was not found"
    exit 1
  fi
}

quick_save() {
  local label="${1:-All sessions}"

  if ! tmux has-session 2>/dev/null; then
    notify-send "Tmux" "No running sessions to save"
    exit 0
  fi

  require_save_script
  tmux run-shell "$save_script"
  notify-send "Tmux saved" "$label $(date '+%Y-%m-%d %H:%M')"
}

if [[ "$mode" == "quick" ]]; then
  quick_save
  exit 0
fi

if ! command -v omarchy-launch-walker >/dev/null 2>&1; then
  notify-send -u critical "Tmux" "omarchy-launch-walker was not found"
  exit 1
fi

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/qvos"
renamed_file="$config_dir/tmux-renamed"

remember_renamed_session() {
  local session="$1"

  install -d "$config_dir"
  {
    [[ -f $renamed_file ]] && grep -v '^[[:space:]]*$' "$renamed_file" || true
    printf '%s\n' "$session"
  } | sort -u >"$renamed_file.tmp"
  mv "$renamed_file.tmp" "$renamed_file"
}

exact_session_exists() {
  local session="$1"

  tmux has-session -t "=$session" 2>/dev/null
}

normalize_session_name() {
  local name="$1"

  name="${name//$'\n'/ }"
  name="${name//$'\t'/ }"
  name="${name//:/-}"
  printf '%s\n' "$name" | sed -E 's/^[[:space:]]+//;s/[[:space:]]+$//'
}

current_dir() {
  omarchy-cmd-terminal-cwd 2>/dev/null || printf '%s\n' "$HOME"
}

create_and_save_session() {
  local new_name="$1"
  local cwd

  cwd="$(current_dir)"
  tmux new-session -d -s "$new_name" -c "$cwd"
  remember_renamed_session "$new_name"
  tmux run-shell "$save_script"
  notify-send "Tmux created and saved" "$new_name $(date '+%Y-%m-%d %H:%M')"
}

session="$(
  {
    printf 'Save all\n'
    tmux list-sessions -F '#S' 2>/dev/null || true
  } |
    omarchy-launch-walker --dmenu --width 420 --minheight 1 --maxheight 420 -p "Save tmux..."
)"
[[ -n "${session:-}" ]] || exit 0
session="$(normalize_session_name "$session")"
[[ -n "${session:-}" ]] || exit 0

require_save_script

if [[ "$session" == "Save all" ]]; then
  quick_save
  exit 0
fi

if exact_session_exists "$session"; then
  quick_save "All sessions (selected: $session)"
  exit 0
fi

create_and_save_session "$session"
