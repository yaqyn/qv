#!/bin/bash
set -euo pipefail

mode="${1:-dialog}"

if ! command -v tmux >/dev/null 2>&1; then
  notify-send -u critical "Tmux" "tmux is not installed"
  exit 1
fi

if ! tmux has-session 2>/dev/null; then
  notify-send "Tmux" "No running session to save"
  exit 0
fi

quick_save() {
  local session save_script

  session="$(tmux display-message -p '#S' 2>/dev/null || tmux list-sessions -F '#S' 2>/dev/null | head -n1)"
  save_script="$HOME/.tmux/plugins/tmux-resurrect/scripts/save.sh"

  if [[ ! -x "$save_script" ]]; then
    notify-send -u critical "Tmux" "tmux-resurrect save script was not found"
    exit 1
  fi

  tmux run-shell "$save_script"
  notify-send "Tmux saved" "${session:-session} $(date '+%Y-%m-%d %H:%M')"
}

if [[ "$mode" == "quick" ]]; then
  quick_save
  exit 0
fi

if ! command -v omarchy-launch-walker >/dev/null 2>&1; then
  notify-send -u critical "Tmux" "omarchy-launch-walker was not found"
  exit 1
fi

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/qvos"
renamed_file="$config_dir/tmux-renamed"
save_script="$HOME/.tmux/plugins/tmux-resurrect/scripts/save.sh"

require_save_script() {
  if [[ ! -x $save_script ]]; then
    notify-send -u critical "Tmux" "tmux-resurrect save script was not found"
    exit 1
  fi
}

remember_renamed_session() {
  local session="$1"

  install -d "$config_dir"
  {
    [[ -f $renamed_file ]] && grep -v '^[[:space:]]*$' "$renamed_file" || true
    printf '%s\n' "$session"
  } | sort -u >"$renamed_file.tmp"
  mv "$renamed_file.tmp" "$renamed_file"
}

exact_session_exists() {
  local session="$1"

  tmux has-session -t "=$session" 2>/dev/null
}

latest_session() {
  tmux display-message -p '#S' 2>/dev/null ||
    {
      tmux list-sessions -F '#{session_activity}	#{session_name}' 2>/dev/null |
        sort -rn -k1,1 |
        head -n1 |
        cut -f2-
    }
}

save_as_new() {
  local new_name="$1"
  local source_session

  source_session="$(latest_session)"
  [[ -n "${source_session:-}" ]] || {
    notify-send "Tmux" "No running session to save"
    exit 0
  }

  tmux rename-session -t "=$source_session" "$new_name"
  remember_renamed_session "$new_name"
  tmux run-shell "$save_script"
  notify-send "Tmux saved as" "$new_name $(date '+%Y-%m-%d %H:%M')"
}

session="$(
  tmux list-sessions -F '#S' 2>/dev/null |
    omarchy-launch-walker --dmenu --width 420 --minheight 1 --maxheight 420 -p "Save tmux..."
)"
[[ -n "${session:-}" ]] || exit 0

require_save_script

if ! exact_session_exists "$session"; then
  save_as_new "$session"
  exit 0
fi

tmux run-shell "$save_script"
notify-send "Tmux saved" "$session $(date '+%Y-%m-%d %H:%M')"
