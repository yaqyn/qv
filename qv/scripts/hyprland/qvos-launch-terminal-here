#!/bin/bash
set -euo pipefail

mode="${1:-terminal}"
search_root="${QVOS_PROJECT_ROOT:-$HOME}"

current_location() {
  QVOS_LOCATION_SEARCH_ROOT="$search_root" ~/.local/share/qvos/hyprland/qvos-active-location
}

location="$(current_location)"
[[ -d "$location" ]] || location="$HOME"

case "$mode" in
tmux)
  # shellcheck disable=SC2016 # Expanded by the inner bash -lc, not this launcher.
  exec uwsm-app -- xdg-terminal-exec --dir="$location" bash -lc '
      if ! tmux has-session 2>/dev/null; then
        tmux new-session -d -s qvos-restore
        tmux source-file "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf" >/dev/null 2>&1 || true
        tmux run-shell "$HOME/.tmux/plugins/tmux-resurrect/scripts/restore.sh" >/dev/null 2>&1 || true
        sleep 1
        if [ "$(tmux list-sessions -F "#S" 2>/dev/null | wc -l)" -gt 1 ]; then
          tmux kill-session -t qvos-restore 2>/dev/null || true
        fi
      fi
      tmux attach || tmux new -s Work
    '
  ;;
terminal)
  exec uwsm-app -- xdg-terminal-exec --dir="$location"
  ;;
root)
  exec uwsm-app -- xdg-terminal-exec --dir="$location" sudo -i
  ;;
*)
  printf 'Usage: qvos-launch-terminal-here [terminal|tmux|root]\n' >&2
  exit 1
  ;;
esac
