#!/bin/bash
set -euo pipefail

if ! command -v omarchy-launch-walker >/dev/null 2>&1; then
  notify-send -u critical "Dev menu" "omarchy-launch-walker was not found"
  exit 1
fi

items_file="${XDG_CONFIG_HOME:-$HOME/.config}/qvos/dev-menu.tsv"
cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/qvos"
lookup_file="$cache_dir/dev-menu-apps.tsv"

ensure_items_file() {
  if [[ -f "$items_file" ]]; then
    return
  fi

  install -d "$(dirname "$items_file")"
  cat >"$items_file" <<'EOF'
GitHub	https://github.com
Cloudflare	https://dash.cloudflare.com
Supabase	https://supabase.com/dashboard
Infisical	https://app.infisical.com
Codespaces	https://github.com/codespaces
EOF
}

menu() {
  local prompt="$1"
  local options="$2"

  printf '%s\n' "$options" |
    omarchy-launch-walker --dmenu --width 420 --minheight 1 --maxheight 420 -p "$prompt..."
}

item_names() {
  cut -f1 "$items_file"
}

item_url() {
  local name="$1"

  awk -F '\t' -v name="$name" '$1 == name { print (NF >= 3 ? $3 : $2); exit }' "$items_file"
}

item_kind() {
  local name="$1"

  awk -F '\t' -v name="$name" '$1 == name { print (NF >= 3 ? $2 : "url"); exit }' "$items_file"
}

desktop_id_from_file() {
  basename "$1" .desktop
}

desktop_name_from_file() {
  awk -F= '
    /^\[Desktop Entry\]/ { entry = 1; next }
    /^\[/ && entry { exit }
    entry && /^Name=/ { print substr($0, 6); exit }
  ' "$1"
}

desktop_is_visible() {
  ! grep -Eq '^(NoDisplay|Hidden)=true$' "$1"
}

build_desktop_lookup() {
  local dir file id name

  install -d "$cache_dir"
  : >"$lookup_file"

  for dir in "$HOME/.local/share/applications" /usr/local/share/applications /usr/share/applications; do
    [[ -d "$dir" ]] || continue
    while IFS= read -r file; do
      desktop_is_visible "$file" || continue
      id="$(desktop_id_from_file "$file")"
      name="$(desktop_name_from_file "$file")"
      [[ -n "$id" && -n "$name" ]] || continue
      printf '%s\t%s\n' "$name" "$id"
    done < <(find "$dir" -maxdepth 1 -type f -name '*.desktop' -print 2>/dev/null)
  done | awk -F '\t' '!seen[$1]++' | sort -f >"$lookup_file"
}

desktop_app_names() {
  cut -f1 "$lookup_file"
}

desktop_app_id() {
  local name="$1"

  awk -F '\t' -v name="$name" '$1 == name { print $2; exit }' "$lookup_file"
}

desktop_id_exists() {
  local id="$1"
  local dir

  for dir in "$HOME/.local/share/applications" /usr/local/share/applications /usr/share/applications; do
    [[ -f "$dir/$id.desktop" ]] && return 0
  done

  return 1
}

prune_stale_apps() {
  local changed kind target

  [[ -f "$items_file" ]] || return 0
  changed=0
  : >"$items_file.tmp"

  while IFS=$'\t' read -r name second third; do
    [[ -n "${name:-}" ]] || continue
    kind="${third:+$second}"
    target="${third:-$second}"
    [[ -n "$kind" ]] || kind="url"

    if [[ "$kind" == "app" ]] && ! desktop_id_exists "$target"; then
      changed=1
      continue
    fi

    if [[ -n "${third:-}" ]]; then
      printf '%s\t%s\t%s\n' "$name" "$kind" "$target" >>"$items_file.tmp"
    else
      printf '%s\t%s\n' "$name" "$target" >>"$items_file.tmp"
    fi
  done <"$items_file"

  mv "$items_file.tmp" "$items_file"
  [[ "$changed" -eq 0 ]] || notify-send "Dev menu" "Removed uninstalled apps"
}

write_item() {
  local name="$1"
  local kind="$2"
  local target="$3"

  grep -v -F "$(printf '%s\t' "$name")" "$items_file" >"$items_file.tmp" || true
  mv "$items_file.tmp" "$items_file"
  printf '%s\t%s\t%s\n' "$name" "$kind" "$target" >>"$items_file"
  notify-send "Dev menu" "Added $name"
}

add_app() {
  local selected id

  build_desktop_lookup
  selected="$(menu "Add app" "$(desktop_app_names)")"
  [[ -n "$selected" ]] || exit 0

  id="$(desktop_app_id "$selected")"
  [[ -n "$id" ]] || {
    notify-send -u critical "Dev menu" "Could not resolve selected app"
    exit 1
  }

  write_item "$selected" app "$id"
}

add_url() {
  local name url

  name="$(menu "Name" "")"
  [[ -n "$name" ]] || exit 0

  url="$(menu "URL" "")"
  [[ "$url" == http://* || "$url" == https://* ]] || {
    notify-send -u critical "Dev menu" "URL must start with http:// or https://"
    exit 1
  }

  write_item "$name" url "$url"
}

add_item() {
  local source

  source="$(menu "Add" "Choose app
New URL")"

  case "$source" in
  "Choose app") add_app ;;
  "New URL") add_url ;;
  esac
}

remove_item() {
  local name

  name="$(menu "Remove" "$(item_names)")"
  [[ -n "$name" ]] || exit 0

  grep -v -F "$(printf '%s\t' "$name")" "$items_file" >"$items_file.tmp" || true
  mv "$items_file.tmp" "$items_file"
  notify-send "Dev menu" "Removed $name"
}

ensure_items_file
prune_stale_apps

choice="$(
  {
    item_names
    printf '%s\n' "+ Add item" "- Remove item"
  } | omarchy-launch-walker --dmenu --width 420 --minheight 1 --maxheight 420 -p "Dev..."
)"

case "$choice" in
"+ Add item") add_item ;;
"- Remove item") remove_item ;;
"")
  exit 0
  ;;
*)
  url="$(item_url "$choice")"
  [[ -n "$url" ]] || exit 0
  case "$(item_kind "$choice")" in
  app) exec setsid gtk-launch "$url" ;;
  *) exec omarchy-launch-webapp "$url" ;;
  esac
  ;;
esac
