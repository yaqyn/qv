#!/bin/bash
set -euo pipefail

current_location() {
  ~/.local/share/qvos/hyprland/qvos-active-location
}

location="$(current_location)"
[[ -d "$location" ]] || location="$HOME"

if command -v omarchy-launch-editor >/dev/null 2>&1; then
  exec env EDITOR="${EDITOR:-${VISUAL:-}}" omarchy-launch-editor "$location"
fi

editor_cmd="${EDITOR:-${VISUAL:-}}"
if [[ -z $editor_cmd ]]; then
  notify-send -u critical "Editor" "No default editor is configured"
  exit 1
fi

case "$editor_cmd" in
nvim | vim | nano | micro | hx | helix | fresh)
  exec uwsm-app -- xdg-terminal-exec --dir="$location" -e "$editor_cmd" .
  ;;
code | code-oss | codium | vscodium)
  exec setsid uwsm-app -- "$editor_cmd" --new-window "$location"
  ;;
*)
  exec setsid uwsm-app -- "$editor_cmd" "$location"
  ;;
esac
