  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#707070", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage", "storage.type"],
      "settings": { "foreground": "#b01616" }
    },
    {
      "scope": ["keyword.operator", "operator"],
      "settings": { "foreground": "#909090" }
    },
    {
      "scope": ["constant", "constant.language", "constant.numeric", "support.type", "entity.name.type", "variable.language"],
      "settings": { "foreground": "#c73535" }
    },
    {
      "scope": ["string", "constant.character", "punctuation.definition.string"],
      "settings": { "foreground": "#c8c8c8" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call", "variable.function"],
      "settings": { "foreground": "#e0e0e0" }
    },
    {
      "scope": ["variable", "variable.other", "support.variable", "meta.property", "variable.other.property"],
      "settings": { "foreground": "#d0d0d0" }
    },
    {
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": { "foreground": "#909090" }
    },
    {
      "scope": ["markup.heading", "markup.bold", "markup.italic", "markup.quote", "markup.raw"],
      "settings": { "foreground": "#d0d0d0" }
    },
    {
      "scope": ["markup.inserted", "markup.inserted.diff", "markup.inserted.diff.git_gutter"],
      "settings": { "foreground": "#9a9a9a", "background": "#101010" }
    },
    {
      "scope": ["markup.changed", "markup.changed.diff"],
      "settings": { "foreground": "#b0b0b0", "background": "#101010" }
    },
    {
      "scope": ["markup.deleted", "markup.deleted.diff", "markup.deleted.diff.git_gutter"],
      "settings": { "foreground": "#991313", "background": "#180505" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#b01616" }
    }
  ]
}
